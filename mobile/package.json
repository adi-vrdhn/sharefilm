{
  "name": "filmshare-mobile",
  "version": "1.0.0",
  "description": "FilmShare mobile app for iOS and Android",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "build:ios": "eas build --platform ios",
